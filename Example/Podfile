platform :ios, '15.6'
use_frameworks!

# ignore all warnings from all pods
inhibit_all_warnings!

target 'ForYouAndMe_Example' do
  pod 'ForYouAndMe', :path => '../', :inhibit_warnings => false
  
  target 'ForYouAndMe_Tests' do
    inherit! :search_paths
    
    pod 'Quick', '~> 1.2.0'
    pod 'Nimble', '~> 7.0'
    pod 'SwiftLint'
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Force deployment target to avoid libarclite issues during lint/trunk push
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.6'

      # Fix forced pod signing issue on azure
      config.build_settings['EXPANDED_CODE_SIGN_IDENTITY'] = ""
      config.build_settings['CODE_SIGNING_REQUIRED'] = "NO"
      config.build_settings['CODE_SIGNING_ALLOWED'] = "NO"
    end

    if target.name == 'ForYouAndMe'
      target.build_configurations.each do |config|
        config.build_settings['ENABLE_TESTABILITY'] = 'YES'
        config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-Onone'
        # Enable HealthKit
        config.build_settings['SWIFT_ACTIVE_COMPILATION_CONDITIONS'] = '$(inherited) HEALTHKIT'
      end
    end

    # Test pods (Quick / Nimble) link against XCTest — enable test search paths
    # so Xcode can resolve libswiftXCTest.dylib for device + simulator builds.
    # Xcode 26 ships swiftXCTest at .../usr/lib/swift-5.0/<platform>/, so we add
    # that path explicitly because Nimble's stock xcconfig only points at
    # swift/<platform>/.
    if ['Quick', 'Nimble'].include?(target.name)
      target.build_configurations.each do |config|
        config.build_settings['ENABLE_TESTING_SEARCH_PATHS'] = 'YES'
        config.build_settings['LIBRARY_SEARCH_PATHS'] = [
          '$(inherited)',
          '"$(PLATFORM_DIR)/Developer/usr/lib"',
          '"${TOOLCHAIN_DIR}/usr/lib/swift-5.0/${PLATFORM_NAME}"',
          '"${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}"',
          '/usr/lib/swift'
        ]
      end
    end
  end

  installer.pods_project.build_configurations.each do |config|
    config.build_settings["EXCLUDED_ARCHS[sdk=iphonesimulator*]"] = "arm64"
  end
end
